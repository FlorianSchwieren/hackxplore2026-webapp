# Supabase (leave blank during mock phase)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stadia Maps API key (get free key at client.stadiamaps.com)
# Can be empty for localhost development — Stadia allows it
VITE_STADIA_API_KEY=

# FastAPI backend (React dashboard reads API only — see docs/09)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Set to "true" to use mock data instead of the backend
VITE_USE_MOCK_DATA=true
