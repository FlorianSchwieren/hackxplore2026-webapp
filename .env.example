# Supabase (leave blank during mock phase)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stadia Maps API key (get free key at client.stadiamaps.com)
# Can be empty for localhost development — Stadia allows it
VITE_STADIA_API_KEY=

# Set to "true" to use mock data instead of Supabase
VITE_USE_MOCK_DATA=true
